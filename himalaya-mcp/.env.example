# MCP server bind
MCP_HOST=0.0.0.0
MCP_PORT=9201

# Himalaya config
# Directory containing config.toml (server resolves config.toml inside it)
HIMALAYA_CONFIG_DIR=/config
# Account name to use for tools when no explicit `account` arg is given.
# Leave EMPTY to let himalaya auto-select the account marked `default = true`
# in config.toml. Set only if you need to override the default.
DEFAULT_ACCOUNT=
DRAFTS_FOLDER=Drafts

# Data dir for attachment downloads (container path)
DATA_DIR=/data
