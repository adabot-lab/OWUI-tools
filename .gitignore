# --- Environment files (ignore all by default) ---
.env
.env.*
*.env

# Allow safe templates
!.env.example
!.env.template
!.env.sample

# --- Private keys / certificates ---
*.key
*.pem
*.p12
*.pfx
*.crt

# --- Other common secret files ---
secrets.*
*.secret
*.credentials
*.token

# --- Local config overrides ---
*.local
config.local.*

# --- Himalaya live config + credentials (himalaya-mcp) ---
himalaya-mcp/config/
himalaya-mcp/config/config.toml
himalaya-mcp/password
himalaya-mcp/password.*
himalaya-mcp/data/

# Allow safe templates
!himalaya-mcp/config.example.toml
